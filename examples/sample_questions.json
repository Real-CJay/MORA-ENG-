    {
      "id": "FLUID_2024_KINVISC_MCQ",
      "subject": "fluid",
      "unit": "Fluid Properties",
      "topic": "Kinematic viscosity",
      "year": "2024",
      "type": "mcq",
      "body": [
        {
          "type": "text",
          "value": "A fluid has dynamic viscosity \\(\\mu = 1.0 \\times 10^{-3}\\,\\mathrm{Pa\\,s}\\) and density \\(\\rho = 1000\\,\\mathrm{kg/m^3}\\). What is its kinematic viscosity \\(\\nu\\)?"
        }
      ],
      "options": [
        {
          "label": "a",
          "body": [{ "type": "text", "value": "$1.0 \\times 10^{-3}\\,\\mathrm{m^2/s}$" }]
        },
        {
          "label": "b",
          "body": [{ "type": "text", "value": "$1.0 \\times 10^{-4}\\,\\mathrm{m^2/s}$" }]
        },
        {
          "label": "c",
          "body": [{ "type": "text", "value": "$1.0 \\times 10^{-6}\\,\\mathrm{m^2/s}$" }]
        },
        {
          "label": "d",
          "body": [{ "type": "text", "value": "$1.0 \\times 10^{6}\\,\\mathrm{m^2/s}$" }]
        }
      ],
      "answer": { "mode": "single", "value": "c" },
      "explanation": [
        {
          "type": "text",
          "value": "Kinematic viscosity is \\(\\nu = \\mu/\\rho\\). Therefore \\(\\nu = (1.0 \\times 10^{-3})/1000 = 1.0 \\times 10^{-6}\\,\\mathrm{m^2/s}\\)."
        }
      ],
      "source": { "pdf": "Fluid_Mechanics_2024.pdf", "page": 2, "qno": 1 },
      "status": "published"
    },
